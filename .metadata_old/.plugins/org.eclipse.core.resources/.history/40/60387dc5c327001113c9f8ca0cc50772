				<textFieldExpression><![CDATA[(
$F{DiplomadoNacionalidade}

+
(
    $F{NaturalidadeNomeMunicipioEstrangeiro} != null &&
    !$F{NaturalidadeNomeMunicipioEstrangeiro}.trim().isEmpty()

    ?

    ", natural " +
    (
        $F{NaturalidadeNomeMunicipioEstrangeiro}.equalsIgnoreCase("Estados Unidos") ? "dos " :
        $F{NaturalidadeNomeMunicipioEstrangeiro}.equalsIgnoreCase("Países Baixos") ? "dos " :
        $F{NaturalidadeNomeMunicipioEstrangeiro}.equalsIgnoreCase("Emirados Árabes Unidos") ? "dos " :
        $F{NaturalidadeNomeMunicipioEstrangeiro}.equalsIgnoreCase("Portugal") ? "de " :
        $F{NaturalidadeNomeMunicipioEstrangeiro}.equalsIgnoreCase("Cuba") ? "de " :
        $F{NaturalidadeNomeMunicipioEstrangeiro}.equalsIgnoreCase("Moçambique") ? "de " :
        $F{NaturalidadeNomeMunicipioEstrangeiro}.toLowerCase().endsWith("a") ? "da " :
        "do "
    )
    + $F{NaturalidadeNomeMunicipioEstrangeiro}

    :

    ", natural do Estado " +
    (
        $F{NaturalidadeUF}.equals("AC") ? "do Acre" :
        $F{NaturalidadeUF}.equals("AL") ? "de Alagoas" :
        $F{NaturalidadeUF}.equals("AP") ? "do Amapá" :
        $F{NaturalidadeUF}.equals("AM") ? "do Amazonas" :
        $F{NaturalidadeUF}.equals("BA") ? "da Bahia" :
        $F{NaturalidadeUF}.equals("CE") ? "do Ceará" :
        $F{NaturalidadeUF}.equals("DF") ? "do Distrito Federal" :
        $F{NaturalidadeUF}.equals("ES") ? "do Espírito Santo" :
        $F{NaturalidadeUF}.equals("GO") ? "de Goiás" :
        $F{NaturalidadeUF}.equals("MA") ? "do Maranhão" :
        $F{NaturalidadeUF}.equals("MT") ? "do Mato Grosso" :
        $F{NaturalidadeUF}.equals("MS") ? "do Mato Grosso do Sul" :
