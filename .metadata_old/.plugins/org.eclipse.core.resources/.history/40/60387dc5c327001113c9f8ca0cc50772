				</textElement>
				<textFieldExpression><![CDATA["A " + $F{FrenteFuncao} + " da Universidade Cesumar - Unicesumar,\n no uso de suas atribuições e tendo em vista a conclusão em "
+ new SimpleDateFormat("dd 'de' MMMM 'de' yyyy", new Locale("pt", "BR"))
    .format(new SimpleDateFormat("yyyy-MM-dd").parse($F{DadosCursoDataConclusao}))
+ ", do \n Curso Superior de " + $F{DadosCursoNomeCurso}
+ ", e a colação de grau \nem "
+ new SimpleDateFormat("dd 'de' MMMM 'de' yyyy", new Locale("pt", "BR"))
    .format(new SimpleDateFormat("yyyy-MM-dd").parse($F{DataColacaoGrau}))
+
(
    $F{DadosCursoNomeCurso} != null && $F{DadosCursoNomeCurso}.equalsIgnoreCase("Psicologia")
        ? ($F{DiplomadoSexo} != null && $F{DiplomadoSexo}.equalsIgnoreCase("F")
            ? ", confere os títulos de Bacharela e Psicóloga a "
            : ", confere os títulos de Bacharel e Psicólogo a ")
    :
    $F{DadosCursoNomeCurso} != null && $F{DadosCursoNomeCurso}.equalsIgnoreCase("Medicina")
        ? ($F{DiplomadoSexo} != null && $F{DiplomadoSexo}.equalsIgnoreCase("F")
            ? ", confere os títulos de Bacharela e Médica a "
            : ", confere os títulos de Bacharel e Médico a ")
    :
    $F{DadosCursoNomeCurso} != null && $F{DadosCursoNomeCurso}.equalsIgnoreCase("Odontologia")
        ? ($F{DiplomadoSexo} != null && $F{DiplomadoSexo}.equalsIgnoreCase("F")
            ? ", confere os títulos de Bacharela e Cirurgiã-Dentista a "
            : ", confere os títulos de Bacharel e Cirurgião-Dentista a ")
    :
    ", confere o título de " +
    (
        $F{DadosCursoOutroTitulo} != null && !$F{DadosCursoOutroTitulo}.trim().isEmpty()
            ? $F{DadosCursoOutroTitulo}
            : (
                $F{DadosCursoTituloConferido} != null
                    ? (
                        $F{DadosCursoTituloConferido}.equalsIgnoreCase("Bacharel")
                            ? ($F{DiplomadoSexo} != null && $F{DiplomadoSexo}.equalsIgnoreCase("F") ? "Bacharela" : "Bacharel")
                        : $F{DadosCursoTituloConferido}.equalsIgnoreCase("Licenciado")
                            ? ($F{DiplomadoSexo} != null && $F{DiplomadoSexo}.equalsIgnoreCase("F") ? "Licenciada" : "Licenciado")
                        : $F{DadosCursoTituloConferido}.equalsIgnoreCase("Tecnólogo")
                            ? ($F{DiplomadoSexo} != null && $F{DiplomadoSexo}.equalsIgnoreCase("F") ? "Tecnóloga" : "Tecnólogo")
                        : $F{DadosCursoTituloConferido}
                    )
                    : $F{DadosCursoGrauConferido}
            )
    )
    + " em " + $F{DadosCursoNomeCurso} + " a "
)]]></textFieldExpression>
