($F{DataInicio} != null ? 
 new java.text.SimpleDateFormat("dd/MM/yyyy").format($F{DataInicio}) : "DATA NÃO INFORMADA") + " a " +
($F{DataConclusao} != null ? 
 new java.text.SimpleDateFormat("dd/MM/yyyy").format($F{DataConclusao}) : "DATA NÃO INFORMADA") + ".\n\n" +
$F{NomeMunicipio}.toLowerCase() + ", "
