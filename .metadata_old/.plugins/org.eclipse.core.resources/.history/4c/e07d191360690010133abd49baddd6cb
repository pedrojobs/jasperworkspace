                <reportElement x="0" y="0" width="555" height="180"/>
                <textElement>
                    <font size="12"/>
                </textElement>
                <textFieldExpression><![CDATA[
"Declaro que " + $F{Nome} + " - Registro acadêmico: " + $F{ID} + ", CPF: " + $F{CPF} + 
" - concluiu a " + $F{NomeCurso} + ", oferecida pelo " + $F{IesEmissoraNome} + 
" com programa Recredenciado pela Comissão Nacional de Residência Médica-MEC, sob parecer 625/2019, processo 2019-108, aprovado em " + 
