				<textFieldExpression><![CDATA["A Pró Reitora do " + $F{IesEmissoraNome}
+ ", no uso de suas atribuições e tendo em vista a conclusão do Curso de graduação em " + $F{DadosCursoNomeCurso}
+ ", em " + new SimpleDateFormat("dd 'de' MMMM 'de' yyyy", new Locale("pt", "BR")).format(
    new SimpleDateFormat("yyyy-MM-dd").parse($F{DadosCursoDataConclusao})
)
+ ", e a colação de grau em " + new SimpleDateFormat("dd 'de' MMMM 'de' yyyy", new Locale("pt", "BR")).format(
    new SimpleDateFormat("yyyy-MM-dd").parse($F{DataColacaoGrau})
)
+ ", confere o título de "
+ (
    ($F{DadosCursoTituloConferido} != null && $F{DiplomadoSexo} != null)
    ? (
        $F{DadosCursoTituloConferido}.equalsIgnoreCase("BACHAREL")
            ? ($F{DiplomadoSexo}.equalsIgnoreCase("F") ? "BACHARELA " : "BACHAREL ")
            : $F{DadosCursoTituloConferido}.equalsIgnoreCase("Licenciado")
                ? ($F{DiplomadoSexo}.equalsIgnoreCase("F") ? "Licenciada " : "Licenciado ")
                : $F{DadosCursoTituloConferido} + " "
    )
    : ($F{DadosCursoTituloConferido} != null ? $F{DadosCursoTituloConferido} + " " : "")
)
+"em "+ $F{DadosCursoNomeCurso}
+ " a "
+ (
    ($F{DiplomadoNomeSocial} != null && !$F{DiplomadoNomeSocial}.trim().isEmpty())
    ? $F{DiplomadoNomeSocial}
    : $F{DiplomadoNome}
)
+
($F{DiplomadoRGNumero} != null ? ", RG nº " +$F{DiplomadoRGNumero} +" "+ $F{DiplomadoRGOrgaoExpedidor}+"/"+$F{DiplomadoRGUF}+ "" : $F{DiplomadoOutroDocTipo} != null ? " " + $F{DiplomadoOutroDocTipo} + " n° " + $F{DiplomadoOutroDocIdentificador} : "") +($F{DiplomadoSexo}.equals("M") ? ", nascido em " : ", nascida em ") + 
new SimpleDateFormat("dd 'de' MMMM 'de' yyyy", new Locale("pt", "BR")).format(new SimpleDateFormat("yyyy-MM-dd").parse($F{DiplomadoDataNascimento})) +
